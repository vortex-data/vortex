{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergePatch",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":combinePatchMinorReleases",
    ":dependencyDashboard",
    ":separateMultipleMajorReleases",
    ":configMigration",
    "group:rust-futuresMonorepo",
    "schedule:earlyMondays",
    "docker:disable"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "autoApprove": true,
  "automergeStrategy": "squash",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  "rebaseWhen": "conflicted",
  "cloneSubmodules": true,
  "platformAutomerge": true,
  "patch": {
    "groupName": "all patch updates"
  },
  "labels": [
    "changelog/chore"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "ubuntu",
        "python"
      ],
      "enabled": false
    },
    {
      "groupName": "arrow-rs",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "matchSourceUrls": [
        "https://github.com/apache/arrow-rs"
      ]
    },
    {
      "groupName": "flatbuffers",
      "matchSourceUrls": [
        "https://github.com/google/flatbuffers"
      ]
    },
    {
      "groupName": "tonic",
      "matchSourceUrls": [
        "https://github.com/hyperium/tonic"
      ]
    }
  ],
  "customManagers": [
    {
      "description": "Update DuckDB version in vortex-duckdb/build.rs",
      "customType": "regex",
      "managerFilePatterns": [
        "/vortex-duckdb/build\\.rs/"
      ],
      "matchStrings": [
        "const DUCKDB_VERSION: &str = \"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\";"
      ],
      "depNameTemplate": "duckdb/duckdb",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}