{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":combinePatchMinorReleases",
    ":dependencyDashboard",
    ":separateMultipleMajorReleases"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "autoApprove": true,
  "automergeStrategy": "squash",
  "rebaseWhen": "conflicted",
  "cloneSubmodules": true,
  "platformAutomerge": true,
  "separateMinorPatch": true,
  "patch": {
    "groupName": "all patch updates"
  },
  "labels": [
    "chore"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "groupName": "datafusion and friends",
      "matchPackageNames": [
        "arrow{/,}**",
        "parquet{/,}**",
        "datafusion{/,}**",
        "pyo3{/,}**"
      ]
    },
    {
      "groupName": "flatbuffers",
      "matchPackageNames": [
        "flatbuffers{/,}**",
        "flexbuffers{/,}**"
      ]
    },
    {
      "groupName": "futures",
      "matchPackageNames": [
        "futures{/,}**"
      ]
    },
    {
      "groupName": "tonic",
      "matchPackageNames": [
        "tonic{/,}**"
      ]
    }
  ],
  "customManagers": [
    {
      "description": "Update DuckDB version in vortex-duckdb/build.rs",
      "customType": "regex",
      "managerFilePatterns": [
        "/vortex-duckdb/build\\.rs/"
      ],
      "matchStrings": [
        "const DUCKDB_VERSION: &str = \"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\";"
      ],
      "depNameTemplate": "duckdb/duckdb",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
