    <LanguageOptions name="TypeScript">
      <option name="fileTypeOverride" value="3" />
      <option name="block" value="false" />
    </LanguageOptions>
    <LanguageOptions name="TypeScript JSX">
      <option name="fileTypeOverride" value="3" />
