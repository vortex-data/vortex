{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [{ "path": "/api/health", "schedule": "*/2 * * * *" }],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/chart/:slug",
      "headers": [
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=300, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
